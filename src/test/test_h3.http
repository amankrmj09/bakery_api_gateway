### Bakery API End-to-End Shopping Cart Flow
@baseUrl = http://localhost:8080
@adminEmail = admin@bakery.com
@adminPassword = Admin@123

### 1. Admin Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "usernameOrEmail": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
    client.test("Admin Login successful", function() {
        client.assert(response.status === 200, "Expected 200 OK");
        client.global.set("admin_token", response.body.access_token);
    });
%}

### 2. Admin Creates Category 1
POST {{baseUrl}}/api/categories
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "name": "Cakes {{ $random.uuid }}",
  "description": "Freshly baked celebration and layered cakes",
  "active": true
}

> {%
    client.test("Category 1 created", function() {
        client.assert(response.status === 201, "Expected 201 Created");
        client.global.set("category1_id", response.body.id);
    });
%}

### 3. Admin Adds Product 1 to Category 1
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "sku": "CKE-{{ $random.uuid }}",
  "name": "Chocolate Fudge Cake",
  "categoryId": "{{category1_id}}",
  "price": 18.00,
  "status": "ACTIVE",
  "unit": "slice",
  "initialStock": 15
}

> {%
    client.test("Product 1 created", function() {
        client.assert(response.status === 201, "Expected 201 Created");
        client.global.set("product1_id", response.body.id);
    });
%}

